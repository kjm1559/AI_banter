# OpenAI API Configuration
# Copy this file to .env and fill in your values

# OpenAI API Base URL (for API endpoints or compatible providers)
# Example for OpenAI: https://api.openai.com/v1
# Example for local deployment: http://localhost:8000/v1
OPENAI_BASE_URL="https://api.openai.com/v1"

# OpenAI API Key
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="your-api-key-here"

# Optional: Model name (default: gpt-4o)
# You can use any compatible model name
OPENAI_MODEL="gpt-4o"
